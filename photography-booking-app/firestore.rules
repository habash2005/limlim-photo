rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
             (request.auth.token.email == "lamawafa13@gmail.com" ||
              request.auth.token.email == "ahmadhijaz325@gmail.com");
    }

    /* ------------ BOOKINGS ------------ */
    match /bookings/{bookingId} {
      allow read: if true;

      allow create: if
        request.method == 'create' &&
        request.resource.data.keys().hasOnly([
          'reference','status','package','date','time','startAt','details','createdAt'
        ]) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.reference is string &&
        request.resource.data.package is map &&
        request.resource.data.package.id is string &&
        request.resource.data.package.name is string &&
        request.resource.data.package.price is number &&
        request.resource.data.package.duration is string &&
        request.resource.data.date is string &&
        request.resource.data.time is string &&
        request.resource.data.startAt is timestamp &&
        request.resource.data.details is map &&
        request.resource.data.details.name is string &&
        request.resource.data.details.email is string &&
        request.resource.data.details.phone is string &&
        request.resource.data.details.location is string;

      allow update, delete: if isAdmin();

      match /images/{imgId} {
        allow read: if true;
        allow create, update: if isAdmin() &&
          request.resource.data.keys().hasOnly([
            "public_id","format","bytes","width","height",
            "secure_url","original_filename","version","createdAt","ref"
          ]) &&
          request.resource.data.public_id is string &&
          request.resource.data.format is string &&
          request.resource.data.bytes is number &&
          request.resource.data.width is number &&
          request.resource.data.height is number &&
          request.resource.data.secure_url is string &&
          request.resource.data.original_filename is string &&
          request.resource.data.version is number &&
          request.resource.data.createdAt is timestamp &&
          request.resource.data.ref is string;
        allow delete: if isAdmin();
      }

      // NEW — Custom album layout document for a booking.
      // Public read so the client portal can render it; admin-only write.
      match /albumLayout/{docId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    /* ------------ GALLERIES ------------ */
    match /galleries/{galleryId} {
      allow read: if true;

      allow create, update: if isAdmin() &&
        request.resource.data.keys().hasOnly([
          "name","slug","tag","codeHash","createdAt","updatedAt"
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.slug is string &&
        request.resource.data.tag is string &&
        request.resource.data.codeHash is string &&
        request.resource.data.createdAt is timestamp &&
        (request.method == 'create' || request.resource.data.updatedAt is timestamp);

      allow delete: if isAdmin();

      match /images/{imgId} {
        allow read: if true;
        allow create, update: if isAdmin() &&
          request.resource.data.keys().hasOnly([
            "public_id","format","bytes","width","height",
            "secure_url","original_filename","version","tag","createdAt"
          ]) &&
          request.resource.data.public_id is string &&
          request.resource.data.format is string &&
          request.resource.data.bytes is number &&
          request.resource.data.width is number &&
          request.resource.data.height is number &&
          request.resource.data.secure_url is string &&
          request.resource.data.original_filename is string &&
          request.resource.data.version is number &&
          request.resource.data.tag is string &&
          request.resource.data.createdAt is timestamp;
        allow delete: if isAdmin();
      }
    }

    match /{document=**} { allow read, write: if false; }
  }
}
